# AI Code Factory v4.7 — Windows Reliability & Git Branch Workflow
# Copy to .env in your project root. Never commit real keys.

# Recommended setup for Lucas:
# Brain / Intake = Claude Code CLI through your Claude plan.
# Executor / implementation = Codex CLI through your ChatGPT/Codex plan.
# Fallback = local heuristic rules.

# Brain provider chain
ACF_AI_INTAKE_PROVIDER=claude-code
ACF_AI_INTAKE_MODE=hybrid
ACF_AI_INTAKE_FALLBACK_CHAIN=claude-code,openai,heuristic
ACF_AI_INTAKE_CONFIDENCE_THRESHOLD=0.55

# Claude Code Brain. Requires Claude Code CLI installed and logged in.
# On Windows, if brain-doctor cannot spawn claude, use the .cmd path from `where.exe claude`, for example:
# ACF_CLAUDE_CODE_COMMAND=C:\Users\fasol\AppData\Roaming\npm\claude.cmd
ACF_CLAUDE_CODE_COMMAND=claude
ACF_CLAUDE_CODE_ARGS=-p
ACF_CLAUDE_CODE_PROMPT_MODE=stdin
ACF_CLAUDE_CODE_TIMEOUT_MS=300000
ACF_CLAUDE_CODE_MAX_RETRIES=1
ACF_CLAUDE_CODE_REQUIRE_JSON=true
ACF_CLAUDE_CODE_SANITIZE_API_ENV=true

# Adaptive routing / consumption control.
# Brain-first: Claude thinks from simple asks onward. Heuristic is last-resort fallback.
ACF_BRAIN_EXTERNAL_MIN_DIFFICULTY=simple
ACF_BRAIN_DEPTH=auto
# Optional per-command override examples:
# npm run ai -- ask "..." --brain-depth architect
# npm run ai -- ask-preview "..." --provider heuristic

# Optional OpenAI fallback. Leave empty unless you want API fallback.
OPENAI_API_KEY=
ACF_AI_INTAKE_MODEL=gpt-4.1
ACF_AI_INTAKE_TIMEOUT_MS=60000

# Executor policy: keep Codex on ChatGPT/Codex login, not API billing.
ACF_EXECUTOR_AUTH=chatgpt
ACF_EXECUTOR_SANITIZE_API_ENV=true
ACF_EXECUTOR_REQUIRE_CHATGPT_LOGIN=true

# API budget guard. Claude Code plan usage is tracked as $0 API cost;
# OpenAI fallback calls are tracked here if enabled.
ACF_AI_BUDGET_ENABLED=true
ACF_AI_MONTHLY_BUDGET_USD=10
ACF_AI_BUDGET_WARN_RATIO=0.8
ACF_AI_BUDGET_HARD_STOP_RATIO=1.0
ACF_AI_BUDGET_FALLBACK_WHEN_EXCEEDED=true


# =====================================================================
# DESIGN ENGINE v4.5 — Reliable Codex design pipeline
# =====================================================================
# Codex CLI is a code agent: it builds HTML mockups, it does NOT create
# raster images. The default provider asks Codex for self-contained HTML
# and the harness rasterizes it to PNG with a local headless browser when
# one is available. If no browser is found, the HTML mockups are accepted
# as valid design artifacts (the pipeline never dead-ends).
#
# Run `npm run ai -- design-doctor` any time to see exactly what will happen.

# Default provider. Uses your Codex/ChatGPT CLI session (no Images API billing).
ACF_DESIGN_PROVIDER=gpt-image
# Equivalent explicit kind:
# ACF_DESIGN_PROVIDER=gpt-image-codex

# Codex command/args override (optional).
# ACF_DESIGN_CODEX_COMMAND=codex
# ACF_DESIGN_CODEX_ARGS=exec --sandbox workspace-write --skip-git-repo-check --config approval_policy="never" -C

# Artifact strategy: html-first (recommended) | image (legacy, needs an image tool).
ACF_DESIGN_CODEX_STRATEGY=html-first

# HTML -> PNG rasterization. Auto-detects Chrome/Chromium/Edge. Override if needed.
ACF_DESIGN_RASTERIZE_HTML=true
# ACF_DESIGN_HTML_RENDERER=/usr/bin/chromium

# If a provider produces zero valid artifacts, walk the fallback chain
# (gpt-image-codex -> gpt-image-api -> wireframe-mock) automatically.
ACF_DESIGN_AUTO_FALLBACK=true

ACF_DESIGN_QUALITY=production-mock
ACF_DESIGN_CREATIVITY=creative-director
ACF_ALLOW_SYNTHETIC_ASSETS=true
ACF_BRAND_BOOTSTRAP=true

# --- Alternative: direct OpenAI Images API (real billing, requires --confirm) ---
# ACF_DESIGN_PROVIDER=gpt-image-api
# OPENAI_API_KEY=sk-...
# ACF_DESIGN_IMAGE_MODEL=gpt-image-2
# ACF_DESIGN_IMAGE_QUALITY=medium
# ACF_DESIGN_IMAGE_FORMAT=png
# ACF_DESIGN_DESKTOP_SIZE=1536x1024
# ACF_DESIGN_MOBILE_SIZE=1024x1536
# ACF_DESIGN_REQUIRE_CONFIRM=true
# ACF_DESIGN_ESTIMATED_COST_PER_IMAGE_USD=0.05

# --- Alternative: offline wireframe mock (no external tools at all) ---
# ACF_DESIGN_PROVIDER=wireframe-mock

# --- Alternative: your own external design CLI ---
# ACF_DESIGN_PROVIDER=external-command
# ACF_DESIGN_COMMAND=your-generic-design-command
# ACF_DESIGN_COMMAND_ARGS=run

# Lightweight research provider: research-web uses DuckDuckGo HTML by default.

# Autonomous Product Loop
ACF_AUTONOMY_MODE=supervised


# Token-efficient Brain Router
ACF_CLAUDE_CODE_PROMPT_MODE=stdin
ACF_CLAUDE_CODE_ARG_PROMPT_MAX_CHARS=1800
# The Brain now routes context by work type and uses summaries under .ai/context-cache.
# Avoid increasing these unless you have a reason.
ACF_BRAIN_EXTERNAL_MIN_DIFFICULTY=simple
ACF_BRAIN_DEPTH=auto



# =====================================================================
# v4.7 Git request workflow
# =====================================================================
# Every implementing REQ is executed on an isolated branch, then committed
# and merged back to the detected base branch (main/master/current) only
# after gates pass. If git is not initialized, cycle stops before coding.
ACF_GIT_WORKFLOW_ENABLED=true
ACF_GIT_BRANCH_PREFIX=acf
ACF_GIT_AUTO_CREATE_BRANCH=true
ACF_GIT_AUTO_COMMIT_ON_SUCCESS=true
ACF_GIT_AUTO_MERGE_ON_SUCCESS=true

# Project bootstrap can add typecheck/test scripts and create an initial git
# baseline in new projects. Run manually once per new repo:
# npm run ai -- project-bootstrap
ACF_PROJECT_BOOTSTRAP_ENABLED=true
